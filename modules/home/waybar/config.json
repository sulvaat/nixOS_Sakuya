{
  "clock": {
    "format": "  {:%a %d %b   %H:%M}",
    "tooltip-format": "<tt><big>{calendar}</big></tt>"
  },
  "cpu": {
    "format": "  {usage}%",
    "interval": 5
  },
  "custom/windows": {
    "exec": "@niri_windows@",
    "format": "  {}",
    "interval": 1,
    "tooltip": false
  },
  "disk": {
    "format": "  {percentage_used}%",
    "interval": 30,
    "path": "/"
  },
  "height": 30,
  "layer": "top",
  "margin-left": 12,
  "margin-right": 12,
  "margin-top": 6,
  "memory": {
    "format": "󰍛  {}%",
    "interval": 5
  },
  "modules-center": [
    "clock"
  ],
  "modules-left": [
    "niri/workspaces",
    "custom/windows"
  ],
  "modules-right": [
    "pulseaudio",
    "memory",
    "cpu",
    "disk",
    "tray"
  ],
  "niri/workspaces": {
    "format": "{value}"
  },
  "position": "top",
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "  {volume}%",
    "format-icons": {
      "default": [
        "",
        "",
        ""
      ]
    },
    "format-muted": "  muted",
    "on-click": "pavucontrol",
    "scroll-step": 5
  },
  "spacing": 6,
  "tray": {
    "icon-size": 18,
    "spacing": 8
  }
}
